{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-grpc-trusted",
      "listen": "0.0.0.0",
      "port": 8443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "00000000-0000-4000-8000-000000000001"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "grpc",
        "security": "tls",
        "grpcSettings": {
          "serviceName": ""
        },
        "tlsSettings": {
          "fingerprint": "firefox",
          "serverName": "",
          "certificates": [
            {
              "certificateFile": "/usr/local/etc/xray/certs/grpc-cert.pem",
              "keyFile": "/usr/local/etc/xray/certs/grpc-key.pem"
            }
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct-out",
      "protocol": "freedom"
    },
    {
      "tag": "client-in-loop",
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 51820
          }
        ]
      }
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "domain": [
          "geosite:ru-available-only-inside",
          "regexp:.*\\.ru$",
          "regexp:.*\\.su$"
        ],
        "outboundTag": "direct-out"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru-whitelist"
        ],
        "outboundTag": "direct-out"
      },
      {
        "type": "field",
        "domain": [
          "geosite:ru-blocked",
          "geosite:ru-blocked-all"
        ],
        "outboundTag": "client-in-loop"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru-blocked"
        ],
        "outboundTag": "client-in-loop"
      },
      {
        "type": "field",
        "inboundTag": [
          "vless-grpc-trusted"
        ],
        "outboundTag": "client-in-loop"
      }
    ]
  }
}
