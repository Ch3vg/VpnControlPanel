{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-reality-in",
      "listen": "0.0.0.0",
      "port": 2053,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "00000000-0000-4000-8000-000000000001",
            "flow": "xtls-rprx-vision"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "ya.ru:443",
          "xver": 0,
          "serverNames": [
            "",
            "ya.ru",
            "gosuslugi.ru",
            "www.microsoft.com",
            "vk.com",
            "kremlin.ru",
            "pochta.ru",
            "government.ru",
            "rzd.ru"
          ],
          "privateKey": "REPLACE_AT_RUNTIME",
          "shortIds": [
            "67f929b3",
            "79952858",
            "3723d2cc"
          ]
        },
        "tcpSettings": {
          "tcpFastOpen": true
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct-out",
      "protocol": "freedom"
    },
    {
      "tag": "client-in-loop",
      "protocol": "socks",
      "settings": {
        "servers": [
          {
            "address": "127.0.0.1",
            "port": 51820
          }
        ]
      }
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "domain": [
          "geosite:ru-available-only-inside",
          "regexp:.*\\.ru$",
          "regexp:.*\\.su$"
        ],
        "outboundTag": "direct-out"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru-whitelist"
        ],
        "outboundTag": "direct-out"
      },
      {
        "type": "field",
        "domain": [
          "geosite:ru-blocked",
          "geosite:ru-blocked-all"
        ],
        "outboundTag": "client-in-loop"
      },
      {
        "type": "field",
        "ip": [
          "geoip:ru-blocked"
        ],
        "outboundTag": "client-in-loop"
      },
      {
        "type": "field",
        "inboundTag": [
          "vless-reality-in"
        ],
        "outboundTag": "client-in-loop"
      }
    ]
  }
}
