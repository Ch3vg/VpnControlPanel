# Allow worker to reload VPN services without password
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl reload xray_reality
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl reload xray_grpc
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl reload xray_xhttp
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl reload xray_client
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl reload hysteria-server
