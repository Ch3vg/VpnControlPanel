# Allow worker to manage per-config VPN units via restricted wrapper.
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /usr/local/bin/vpn-systemctl

# Legacy profile-based services (when systemd.per_config: false)
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl restart xray_reality
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl restart xray_grpc
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl restart xray_xhttp
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl restart xray_client
${VCP_WORKER_USER} ALL=(root) NOPASSWD: /bin/systemctl restart hysteria-server
