# HTTPS (requires Let's Encrypt or other certs). Set VCP_NGINX_SSL=1 in deploy/.env
server {
    listen 80;
    server_name ${VCP_PANEL_DOMAIN};

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    server_name ${VCP_PANEL_DOMAIN};

    ssl_certificate     /etc/letsencrypt/live/${VCP_PANEL_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${VCP_PANEL_DOMAIN}/privkey.pem;

    client_max_body_size 1m;

    location / {
        proxy_pass http://${VCP_API_HOST}:${VCP_API_PORT};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
