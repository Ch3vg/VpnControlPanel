# Copy to deploy/.env and adjust before running make deploy
# cp deploy/env.example deploy/.env

# --- Paths ---
VCP_INSTALL_DIR=/opt/vpn-control-panel
VCP_CONFIG_DIR=/etc/vpn-control-panel
VCP_DATA_DIR=/var/lib/vpn-control-panel
VCP_VPN_CONFIGS_DIR=/opt/vpn/configs
VCP_CERT_DIR=/usr/local/etc/xray/certs
VCP_HYSTERIA_CONFIG_DIR=/usr/local/etc/hysteria
VCP_TEMPLATES_DIR=/opt/vpn-control-panel/configs

# --- OS users ---
VCP_PANEL_USER=vpn-panel
VCP_WORKER_USER=vpn-worker
VCP_WORKER_INSTANCES=1

# --- PostgreSQL (panel DB) ---
VCP_DB_HOST=127.0.0.1
VCP_DB_PORT=5432
VCP_DB_NAME=vpn_panel
VCP_DB_USER=vpn_panel
VCP_DB_PASSWORD=

# --- Secrets (leave empty to auto-generate via make secrets) ---
VCP_JWT_SECRET=
VCP_ENCRYPTION_KEY=
VCP_BROKER_API_KEY=

# --- Network / public ---
VCP_PUBLIC_HOST=vpn.example.com
# VLESS user id for grpc-out upstream (static, set once on upstream server)
VCP_GRPC_OUT_USER_ID=
VCP_PANEL_DOMAIN=panel.example.com
VCP_API_HOST=127.0.0.1
VCP_API_PORT=8000
VCP_BROKER_HOST=127.0.0.1
VCP_BROKER_PORT=8001

# --- Nginx: 0 = HTTP :80 only, 1 = HTTPS :443 (needs certs) ---
VCP_NGINX_SSL=0

# --- task-broker wheel (required for make install-app) ---
VCP_TASK_BROKER_WHL=/path/to/task_broker-1.0.0-py3-none-any.whl

# --- First admin user ---
VCP_ADMIN_USERNAME=admin

# --- Cron: username for vpn-regenerate-all / regenerate-all-configs.sh ---
# VCP_CRON_ADMIN_USERNAME=admin

# --- Optional: set for non-interactive admin creation (discouraged in production) ---
# VCP_ADMIN_PASSWORD=
